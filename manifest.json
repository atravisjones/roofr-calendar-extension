{
  "manifest_version": 3,
  "name": "Roofr Assist",
  "version": "2.1.42",
  "key": "",
  "description": "Extract appointments from Roofr and show availability from Google Sheets.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "minimum_chrome_version": "116",
  "update_url": "https://raw.githubusercontent.com/atravisjones/roofr-calendar-extension/main/updates.xml",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tabGroups",
    "sidePanel",
    "alarms",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.roofr.com/*",
    "https://*.calltrackingmetrics.com/*",
    "https://earth.google.com/*",
    "https://gemini.google.com/*",
    "https://geocoding.geo.census.gov/*",
    "https://sheets.googleapis.com/*",
    "https://raw.githubusercontent.com/*",
    "https://roofr-storage-private.s3.amazonaws.com/*",
    "https://ik.imagekit.io/*",
    "https://ucfqgkbkxbztxlyniuph.supabase.co/*",
    "https://az-roofers-tech-scheduler.vercel.app/*",
    "https://roofr-search.vercel.app/*",
    "https://speed-to-leads.vercel.app/*",
    "https://arizona-roofers-tools.vercel.app/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Roofr Assist",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.roofr.com/*"
      ],
      "js": [
        "roofr-dark-mode.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://*.roofr.com/*",
        "https://*.calltrackingmetrics.com/*",
        "https://earth.google.com/*"
      ],
      "js": [
        "roofr-api.js",
        "reports-batch.js",
        "content.js",
        "roofr-timeline.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.roofr.com/*"
      ],
      "css": [
        "roofr-timeline.css"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.roofr.com/*"
      ],
      "js": [
        "roofr-material-order-newtab.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "dialer-bridge.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "dialer-bridge-main.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dialer.html",
        "dialer.js"
      ],
      "matches": [
        "https://*.calltrackingmetrics.com/*"
      ]
    },
    {
      "resources": [
        "attachment-viewer.html",
        "attachment-viewer.js"
      ],
      "matches": [
        "https://*.roofr.com/*"
      ]
    }
  ],
  "commands": {
    "open-auto-dialer": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Open the Auto-Dialer window"
    }
  }
}
