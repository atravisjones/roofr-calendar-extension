{
  "manifest_version": 3,
  "name": "Roofr Calendar Scraper",
  "version": "2.0.65",
  "description": "Extract appointments from Roofr and show availability from Google Sheets.",
  "minimum_chrome_version": "116",
  "update_url": "https://raw.githubusercontent.com/atravisjones/roofr-calendar-extension/main/updates.xml",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tabGroups",
    "sidePanel",
    "alarms",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://*.roofr.com/*",
    "https://*.calltrackingmetrics.com/*",
    "https://earth.google.com/*",
    "https://gemini.google.com/*",
    "https://api.geoapify.com/*",
    "https://geocoding.geo.census.gov/*",
    "https://us1.locationiq.com/*",
    "https://sheets.googleapis.com/*",
    "https://raw.githubusercontent.com/*",
    "https://ucfqgkbkxbztxlyniuph.supabase.co/*",
    "https://az-roofers-tech-scheduler.vercel.app/*",
    "https://roofr-search.vercel.app/*",
    "https://speed-to-leads.vercel.app/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "action": {
    "default_title": "Roofr Calendar Scraper"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://*.roofr.com/*",
        "https://*.calltrackingmetrics.com/*",
        "https://earth.google.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "dialer-bridge.js"
      ],
      "run_at": "document_idle",
      "all_frames": true
    },
    {
      "matches": [
        "https://*.calltrackingmetrics.com/*"
      ],
      "js": [
        "dialer-bridge-main.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dialer.html",
        "dialer.js"
      ],
      "matches": [
        "https://*.calltrackingmetrics.com/*"
      ]
    }
  ],
  "commands": {
    "open-auto-dialer": {
      "suggested_key": {
        "default": "Alt+Shift+D"
      },
      "description": "Open the Auto-Dialer window"
    }
  }
}
